# Xenomorph Mainnet — Environment Variables
# Copy to .env and fill in your values before running docker compose.
#
# Generate a fresh keypair:
#   ./mainnet.sh keygen
#
# Derive xenom: address from an existing key:
#   ./mainnet.sh addr <64-hex-privkey>
#
# Key architecture:
#   VALIDATOR_PRIVKEY / SETTLEMENT_PRIVKEY / WORKER_PRIVKEY / COORDINATOR_PRIVKEY
#     → same secp256k1 key; used for L2 encryption, signing, and decryption
#   COMMITTER_PRIVKEY
#     → secp256k1 key whose derived xenom: address holds mainnet XENOM
#       for paying L1 anchor transaction fees
#   MINING_ADDR
#     → xenom: address from a separate Schnorr keypair (xenom-wallet)
#       that receives block rewards

# ── Required ─────────────────────────────────────────────────────────────────

# secp256k1 private key shared by coordinator / validator / settlement / worker (64 hex chars)
# Generate with: ./mainnet.sh keygen
VALIDATOR_PRIVKEY=

# secp256k1 private key for anchor committer funding address (64 hex chars)
# Can be the same as VALIDATOR_PRIVKEY, but the derived xenom: address must hold XENOM for L1 fees.
# Derive address with: ./mainnet.sh addr <privkey>
COMMITTER_PRIVKEY=

# Pool keypair — generate with: docker run --rm xenomorph:latest xenom-stratum-bridge --keygen
# The derived xenom: address receives all block rewards; the key signs miner payout transactions.
# MINING_ADDR must be the pool address from this keypair (not a personal wallet address).
POOL_PRIVKEY=

# xenom: pool reward address — MUST match the address derived from POOL_PRIVKEY above
MINING_ADDR=

# xenom: address that receives L2 job rewards paid out by the settlement service
# Can be any xenom: address (e.g. your personal wallet). Derive from VALIDATOR_PRIVKEY with:
#   ./mainnet.sh addr <VALIDATOR_PRIVKEY>
WORKER_MINING_ADDR=

# secp256k1 private key for L2 miner reward payments (64 hex chars)
# IMPORTANT: this address must hold XENOM to pay out rewards to miners.
# It is SEPARATE from COMMITTER_PRIVKEY to avoid UTXO contention with the anchor committer.
# Generate with: ./mainnet.sh keygen   → fund the derived address with ≥10 XENOM
# If not set, falls back to VALIDATOR_PRIVKEY (not recommended — same UTXO pool as committer).
SETTLEMENT_PAYMENT_PRIVKEY=

# ── Optional ─────────────────────────────────────────────────────────────────

# EVM chain ID (default: 7777)
EVM_CHAIN_ID=7777
